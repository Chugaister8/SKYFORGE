# Backend API URL (server-side)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Cesium Ion token — get free token at https://ion.cesium.com/tokens
# Required for 3D globe terrain
NEXT_PUBLIC_CESIUM_TOKEN=

# Feature flags (optional)
NEXT_PUBLIC_ENABLE_CESIUM=true
