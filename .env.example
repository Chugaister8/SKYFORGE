# SKYFORGE — Environment variables
# Copy to .env and fill in values

# ── Required in production ───────────────────────────────────────
SECRET_KEY=your-random-64-char-secret-key-here
DOMAIN=skyforge.yourdomain.com
POSTGRES_PASSWORD=your-strong-db-password

# ── Optional ─────────────────────────────────────────────────────
REDIS_PASSWORD=
NEXT_PUBLIC_CESIUM_TOKEN=

# ── Defaults (override if needed) ────────────────────────────────
ENVIRONMENT=production
ALLOWED_ORIGINS=https://skyforge.yourdomain.com
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_API_DEFAULT=200/minute
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
WS_HEARTBEAT_S=30
WS_MAX_ROOMS=100
